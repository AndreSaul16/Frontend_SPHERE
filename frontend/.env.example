# ===========================
# SPHERE Frontend — Environment Variables
# ===========================

# --- Firebase ---
# Get these from Firebase Console → Project Settings → Your apps
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=sphere-2a4cf.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=sphere-2a4cf
VITE_FIREBASE_STORAGE_BUCKET=sphere-2a4cf.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# --- Backend API URL ---
# Default: http://localhost:8000/api/v1 (local dev)
# In production: set to your Railway backend URL
VITE_API_URL=http://localhost:8000/api/v1
