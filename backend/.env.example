# ===========================
# SPHERE Backend — Environment Variables
# ===========================

# --- Entorno ---
# production | development | local
ENVIRONMENT=development

# --- MongoDB ---
MONGODB_URL=mongodb://localhost:27017
DB_NAME=sphere_db

# --- CORS ---
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- n8n - Workflow Automation ---
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=your-webhook-secret
N8N_API_KEY=your-n8n-api-key

# --- Firebase Auth ---
# Path to Firebase service account JSON
FIREBASE_CREDENTIALS_PATH=./firebase-adminsdk.json

# --- Cifrado de tokens OAuth ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key

# --- OAuth (BYO: cada usuario registra su propia OAuth app) ---
# No hay client_id/secret globales: cada usuario los registra vía
# PUT /api/v1/integrations/{provider}/app y se cifran con FERNET_KEY.
# Lo único global es el callback base (el usuario whitelistea esta URL en su app):
OAUTH_REDIRECT_BASE_URL=http://localhost:8000/api/v1/integrations

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS_PER_MINUTE=30
RATE_LIMIT_CHAT_PER_MINUTE=10
TOKEN_BUDGET_DAILY_DEFAULT=100000
TOKEN_BUDGET_RESET_HOUR_UTC=0

# --- GridFS Quota ---
GRIDFS_QUOTA_MB_PER_USER=500

# --- Timeouts ---
OPENAI_TIMEOUT=15.0
DEEPSEEK_TIMEOUT=60.0
EXTERNAL_API_TIMEOUT=30.0

# --- DeepSeek ---
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- OpenAI ---
OPENAI_API_KEY=your-openai-api-key

# --- Stripe (pagos) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_TOPUP_FREE=
STRIPE_PRICE_TOPUP_STARTER=
STRIPE_PRICE_TOPUP_PREMIUM_1K=
STRIPE_PRICE_TOPUP_PREMIUM_2K=
STRIPE_PRICE_TOPUP_PREMIUM_10K=
FRONTEND_URL=http://localhost:5173
